DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.example.com

# After Vercel deploy, put the real frontend URL here:
CORS_ALLOWED_ORIGINS=http://localhost:8443,http://127.0.0.1:8443,https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
MEDIA_URL=/media/

# Docker Compose sets POSTGRES_* automatically.
# Optional single URL instead:
# DATABASE_URL=postgres://mrii:mrii@db:5432/mrii
