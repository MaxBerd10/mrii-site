DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,fermiclinic.uz,www.fermiclinic.uz

# Same-domain production (Nginx proxies /api /admin /media):
CORS_ALLOWED_ORIGINS=http://localhost:8443,http://127.0.0.1:8443,https://fermiclinic.uz,https://www.fermiclinic.uz
FRONTEND_URL=https://fermiclinic.uz
CSRF_TRUSTED_ORIGINS=https://fermiclinic.uz,https://www.fermiclinic.uz
MEDIA_URL=/media/

# Docker Compose sets POSTGRES_* automatically.
# Optional single URL instead:
# DATABASE_URL=postgres://mrii:mrii@db:5432/mrii
