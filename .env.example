# ── Frontend (Vite) ──────────────────────────────────────────
# No trailing slash. Leave empty = static fallback (CMS o‘qilmaydi).
#
# Local:
VITE_API_URL=http://127.0.0.1:8001
#
# Production (same domain via Nginx — see deploy/README.md):
# VITE_API_URL=https://fermiclinic.uz

# ── Docker Compose / Django (repo root .env on the server) ───
# Copy to `.env` on the VPS, then: docker compose -p mrii-site up -d --build
#
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_ALLOWED_HOSTS=fermiclinic.uz,www.fermiclinic.uz,localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=https://fermiclinic.uz,https://www.fermiclinic.uz
# FRONTEND_URL=https://fermiclinic.uz
# CSRF_TRUSTED_ORIGINS=https://fermiclinic.uz,https://www.fermiclinic.uz
# SEED_SUPERUSER=1
